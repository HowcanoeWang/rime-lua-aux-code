db_pool_={}
local function opendb(fn,dbname) 
  dbname= dbname or ""
  local db = db_pool_[fn]
  if not db then 
    db = LevelDb(fn,dbname) 
    if not db then return nil end
    db_pool_[fn] = db
  end
  if not db:loaded() then db:open() end
  return db
end
local function init_data(db)
  local tab = {
    ab = "于",
    cd = "金",
    ac = "金金",
  }
  for k,v in next,tab do
    db:update(k,v)
  end
end

